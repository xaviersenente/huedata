# Keystatic — GitHub OAuth App
# Créer sur https://github.com/settings/developers > "New OAuth App"
# Homepage URL: https://votre-site.netlify.app
# Authorization callback URL: https://votre-site.netlify.app/api/keystatic/github/oauth/callback
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=

# Secret aléatoire pour les sessions Keystatic (générer avec: openssl rand -hex 32)
KEYSTATIC_SECRET=
