---
import { getCollection, render } from "astro:content";
import Layout from "../layouts/Layout.astro";
import CTA from "../components/sections/CTA.astro";
import Button from "../components/ui/Button.astro";
import { colorTextClass, expertiseCardStyles } from "../data/domains";
import { iconMap } from "../data/icons";
import SectionHeader from "../components/ui/SectionHeader.astro";

const expertises = (await getCollection("expertises")).sort(
  (a, b) => a.data.order - b.data.order,
);

const rendered = await Promise.all(expertises.map((exp) => render(exp)));

const cardColors = expertiseCardStyles;
---

<Layout
  title="Expertises — HueData"
  description="Études quantitatives, analyses qualitatives, stratégie data-driven et impact économique pour les acteurs culturels et événementiels."
>
  {/* Hero page */}
  <section class="relative overflow-hidden bg-noir px-6 pt-40 pb-20">
    <div aria-hidden="true" class="pointer-events-none absolute inset-0">
      <div
        class="blur-blob absolute -top-50 -right-25 h-[500px] w-[500px] bg-electric opacity-20"
      >
      </div>
    </div>
    <div class="relative z-10 mx-auto max-w-7xl">
      <SectionHeader
        tag="Ce qu'on fait"
        tagColor="bg-electric"
        as="h1"
        size="lg"
        titleClass="mb-6 tracking-[-0.03em]"
      >
        Quatre pôles,<br />
        <span class="text-gradient-magenta">une obsession.</span>
      </SectionHeader>
      <p class="max-w-2xl font-body text-xl leading-relaxed text-gray-400">
        Des études rigoureuses, une approche terrain, des recommandations
        actionnables. Pour que vos données travaillent vraiment pour vous.
      </p>
    </div>
  </section>

  {/* Expertises détaillées */}
  <section class="bg-noir px-6 py-16">
    <div class="mx-auto max-w-7xl space-y-6">
      {
        expertises.map((exp, i) => {
          const { Content } = rendered[i];
          const c = cardColors[exp.data.color];
          const Icon = iconMap[exp.data.icon] ?? iconMap.chart;
          return (
            <div
              id={exp.slug}
              data-animate="expertise"
              class="group card-glass hover:border-opacity-60 relative scroll-mt-25 overflow-hidden rounded-2xl border border-gray-800 transition-all duration-500"
            >
              {/* Top accent */}
              <div
                class={`absolute top-0 right-0 left-0 h-0.5 ${c.topGradient}`}
              />

              <div class="grid gap-0 md:grid-cols-2">
                {/* Left: title + icon */}
                <div
                  class={`flex flex-col justify-between border-b border-gray-800 p-8 md:border-r md:border-b-0 md:p-14 ${c.bgPanel}`}
                >
                  <div>
                    <div
                      class={`mb-8 flex h-16 w-16 items-center justify-center rounded-2xl ${c.bgIcon} ${c.text}`}
                    >
                      <Icon />
                    </div>
                    <div
                      class={`mb-4 font-display text-8xl leading-none font-bold select-none ${c.numberText}`}
                    >
                      0{i + 1}
                    </div>
                    <h2 class="mb-4 font-display text-3xl leading-[1.1] font-bold text-creme md:text-4xl">
                      {exp.data.title}
                    </h2>
                    <p class="font-body text-lg leading-relaxed text-gray-400">
                      {exp.data.description}
                    </p>
                  </div>
                </div>

                {/* Right: content + methods */}
                <div class="p-8 md:p-14">
                  <div class="prose-custom mb-8">
                    <Content />
                  </div>
                  {exp.data.methods && exp.data.methods.length > 0 && (
                    <div>
                      <h3 class="mb-4 font-display text-sm font-semibold tracking-widest text-creme uppercase">
                        Méthodes
                      </h3>
                      <ul class="space-y-3">
                        {exp.data.methods.map((method: string) => (
                          <li class="flex items-start gap-3">
                            <span
                              class={`mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full ${c.dot}`}
                            />
                            <span class="font-body text-sm text-gray-400">
                              {method}
                            </span>
                          </li>
                        ))}
                      </ul>
                    </div>
                  )}
                  <Button
                    href="/contact"
                    variant="link"
                    class={`mt-8 text-sm ${colorTextClass[exp.data.color]}`}
                  >
                    Discutons de votre projet
                  </Button>
                </div>
              </div>
            </div>
          );
        })
      }
    </div>
  </section>

  <CTA />
</Layout>

<style>
  .prose-custom :global(p) {
    color: var(--color-gray-400);
    font-family: var(--font-body);
    line-height: 1.7;
    margin-bottom: 1rem;
    font-size: 0.95rem;
  }
</style>

<script>
  import { gsap } from "../lib/gsap";
  import { scrollReveal } from "../lib/animations";

  gsap.utils
    .toArray<HTMLElement>('[data-animate="expertise"]')
    .forEach((el) => {
      scrollReveal(el, el);
    });
</script>
