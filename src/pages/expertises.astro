---
import { getCollection, render } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import CTA from '../components/sections/CTA.astro';
import Button from '../components/ui/Button.astro';
import { colorTextClass, expertiseCardStyles } from '../data/domains';
import IconChart from '../assets/icons/IconChart.svg';
import IconChat from '../assets/icons/IconChat.svg';
import IconTarget from '../assets/icons/IconTarget.svg';
import IconMap from '../assets/icons/IconMap.svg';

const expertises = (await getCollection('expertises')).sort((a, b) => a.data.order - b.data.order);

const iconMap: Record<string, typeof IconChart> = {
  chart: IconChart,
  chat: IconChat,
  target: IconTarget,
  map: IconMap,
};

const cardColors = expertiseCardStyles;
---

<Layout
  title="Expertises — HueData"
  description="Études quantitatives, analyses qualitatives, stratégie data-driven et impact économique pour les acteurs culturels et événementiels."
>
  <!-- Hero page -->
  <section class="pt-40 pb-20 px-6 bg-noir relative overflow-hidden">
    <div aria-hidden="true" class="absolute inset-0 pointer-events-none">
      <div class="blur-blob absolute w-[500px] h-[500px] bg-electric opacity-20 -top-50 -right-25"></div>
    </div>
    <div class="mx-auto max-w-7xl relative z-10">
      <span class="inline-flex items-center gap-2 text-sm text-gray-400 uppercase tracking-widest mb-6">
        <span class="w-6 h-px bg-electric"></span>
        Ce qu'on fait
      </span>
      <h1 class="font-display font-bold text-creme mb-6 text-[clamp(3rem,7vw,6rem)] leading-none tracking-[-0.03em]">
        Quatre pôles,<br />
        <span class="text-gradient-magenta">une obsession.</span>
      </h1>
      <p class="font-body text-gray-400 text-xl max-w-2xl leading-relaxed">
        Des études rigoureuses, une approche terrain, des recommandations actionnables.
        Pour que vos données travaillent vraiment pour vous.
      </p>
    </div>
  </section>

  <!-- Expertises détaillées -->
  <section class="py-16 px-6 bg-noir">
    <div class="mx-auto max-w-7xl space-y-6">
      {expertises.map(async (exp, i) => {
        const { Content } = await render(exp);
        const c = cardColors[exp.data.color];
        const Icon = iconMap[exp.data.icon] ?? iconMap.chart;
        return (
          <div
            id={exp.slug}
            class="group relative rounded-2xl overflow-hidden card-glass border border-gray-800 hover:border-opacity-60 transition-all duration-500 scroll-mt-25"
          >
            <!-- Top accent -->
            <div class={`absolute top-0 left-0 right-0 h-0.5 ${c.topGradient}`}></div>

            <div class="grid md:grid-cols-2 gap-0">
              <!-- Left: title + icon -->
              <div class={`p-10 md:p-14 flex flex-col justify-between border-b md:border-b-0 md:border-r border-gray-800 ${c.bgPanel}`}>
                <div>
                  <div class={`w-16 h-16 rounded-2xl flex items-center justify-center mb-8 ${c.bgIcon} ${c.text}`}>
                    <Icon />
                  </div>
                  <div class={`font-display font-bold text-8xl leading-none mb-4 select-none ${c.numberText}`}>
                    0{i + 1}
                  </div>
                  <h2 class="font-display font-bold text-creme text-3xl md:text-4xl mb-4 leading-[1.1]">
                    {exp.data.title}
                  </h2>
                  <p class="font-body text-gray-400 text-lg leading-relaxed">{exp.data.description}</p>
                </div>
              </div>

              <!-- Right: content + methods -->
              <div class="p-10 md:p-14">
                <div class="prose-custom mb-8">
                  <Content />
                </div>
                {exp.data.methods && exp.data.methods.length > 0 && (
                  <div>
                    <h3 class="font-display font-semibold text-creme text-sm uppercase tracking-widest mb-4">Méthodes</h3>
                    <ul class="space-y-3">
                      {exp.data.methods.map((method: string) => (
                        <li class="flex items-start gap-3">
                          <span class={`mt-1.5 w-1.5 h-1.5 rounded-full shrink-0 ${c.dot}`}></span>
                          <span class="font-body text-gray-400 text-sm">{method}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                )}
                <Button href="/contact" variant="link" class={`mt-8 text-sm ${colorTextClass[exp.data.color]}`}>Discutons de votre projet</Button>
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </section>

  <CTA />
</Layout>

<style>
  .prose-custom :global(p) {
    color: var(--color-gray-400);
    font-family: var(--font-body);
    line-height: 1.7;
    margin-bottom: 1rem;
    font-size: 0.95rem;
  }
</style>

<script>
  import { gsap, ScrollTrigger } from '../lib/gsap';

  gsap.utils.toArray<HTMLElement>('[id^="etudes"], [id^="analyses"], [id^="strategie"], [id^="impact"]').forEach((el) => {
    gsap.fromTo(el,
      { opacity: 0, y: 40 },
      {
        opacity: 1,
        y: 0,
        duration: 0.8,
        ease: 'power3.out',
        scrollTrigger: { trigger: el, start: 'top 75%' },
      }
    );
  });
</script>
