---
import Layout from '../layouts/Layout.astro';
import Button from '../components/ui/Button.astro';

const projectTypes = [
  'Étude de public / satisfaction',
  'Analyse de billetterie',
  'Étude d\'impact économique',
  'Diagnostic stratégique',
  'Étude qualitative',
  'Autre',
];

const sectors = [
  'Festival de musiques actuelles',
  'Salle de concert / SMAC',
  'Musée / Patrimoine',
  'Club sportif',
  'Collectivité territoriale',
  'Association culturelle',
  'Autre',
];
---

<Layout
  title="Contact — HueData"
  description="Décrivez votre projet à HueData. Réponse sous 48h pour toute demande d'étude ou de conseil en marketing culturel."
>
  <!-- Hero -->
  <section class="pt-40 pb-16 px-6 bg-noir relative overflow-hidden">
    <div aria-hidden="true" class="absolute inset-0 pointer-events-none">
      <div class="blur-blob absolute w-[400px] h-[400px] bg-magenta" style="top: -150px; left: -100px; opacity: 0.15;"></div>
      <div class="blur-blob absolute w-[300px] h-[300px] bg-electric" style="bottom: 0; right: 0; opacity: 0.1;"></div>
    </div>
    <div class="mx-auto max-w-3xl relative z-10 text-center">
      <span class="inline-flex items-center gap-2 text-sm text-gray-400 uppercase tracking-widest mb-6">
        <span class="w-6 h-px bg-magenta"></span>
        Parlons data
        <span class="w-6 h-px bg-magenta"></span>
      </span>
      <h1 class="font-display font-bold text-creme mb-6" style="font-size: clamp(3rem, 7vw, 6rem); line-height: 1.0; letter-spacing: -0.03em;">
        Décrire<br />
        <span class="text-gradient-magenta">votre projet.</span>
      </h1>
      <p class="font-body text-gray-400 text-xl leading-relaxed">
        On répond sous 48h. Pas de devis automatisé, pas de template. Une vraie conversation.
      </p>
    </div>
  </section>

  <!-- Formulaire + infos -->
  <section class="py-12 pb-32 px-6 bg-noir">
    <div class="mx-auto max-w-6xl grid md:grid-cols-3 gap-12">

      <!-- Formulaire -->
      <div class="md:col-span-2">
        <form
          id="contact-form"
          class="space-y-6"
          action="https://formspree.io/f/your-form-id"
          method="POST"
          novalidate
        >
          <!-- Nom + Organisation -->
          <div class="grid sm:grid-cols-2 gap-4">
            <div class="form-field">
              <label for="name" class="font-display font-semibold text-creme text-sm mb-2 block">
                Votre nom *
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                placeholder="Florent Sanseigne"
                class="w-full bg-noir-card border border-gray-700 focus:border-magenta rounded-xl px-5 py-4 font-body text-creme placeholder-gray-600 text-base outline-none transition-colors duration-200"
              />
            </div>
            <div class="form-field">
              <label for="organization" class="font-display font-semibold text-creme text-sm mb-2 block">
                Organisation *
              </label>
              <input
                type="text"
                id="organization"
                name="organization"
                required
                placeholder="No Logo Festival"
                class="w-full bg-noir-card border border-gray-700 focus:border-magenta rounded-xl px-5 py-4 font-body text-creme placeholder-gray-600 text-base outline-none transition-colors duration-200"
              />
            </div>
          </div>

          <!-- Email -->
          <div class="form-field">
            <label for="email" class="font-display font-semibold text-creme text-sm mb-2 block">
              Email *
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="florent@no-logo.fr"
              class="w-full bg-noir-card border border-gray-700 focus:border-magenta rounded-xl px-5 py-4 font-body text-creme placeholder-gray-600 text-base outline-none transition-colors duration-200"
            />
          </div>

          <!-- Type de projet -->
          <div class="form-field">
            <label class="font-display font-semibold text-creme text-sm mb-3 block">
              Type de projet
            </label>
            <div class="flex flex-wrap gap-2">
              {projectTypes.map((type) => (
                <label class="project-type-label cursor-pointer">
                  <input type="radio" name="project_type" value={type} class="sr-only" />
                  <span class="inline-block px-4 py-2 rounded-full border border-gray-700 text-gray-400 text-sm font-body cursor-pointer transition-all duration-200 hover:border-magenta hover:text-creme select-none">
                    {type}
                  </span>
                </label>
              ))}
            </div>
          </div>

          <!-- Secteur -->
          <div class="form-field">
            <label for="sector" class="font-display font-semibold text-creme text-sm mb-2 block">
              Secteur d'activité
            </label>
            <select
              id="sector"
              name="sector"
              class="w-full bg-noir-card border border-gray-700 focus:border-magenta rounded-xl px-5 py-4 font-body text-gray-400 text-base outline-none transition-colors duration-200 cursor-pointer"
            >
              <option value="">Choisissez votre secteur</option>
              {sectors.map((s) => <option value={s}>{s}</option>)}
            </select>
          </div>

          <!-- Message -->
          <div class="form-field">
            <label for="message" class="font-display font-semibold text-creme text-sm mb-2 block">
              Décrivez votre projet *
            </label>
            <textarea
              id="message"
              name="message"
              required
              rows={6}
              placeholder="Contexte, objectifs, échéance, budget indicatif..."
              class="w-full bg-noir-card border border-gray-700 focus:border-magenta rounded-xl px-5 py-4 font-body text-creme placeholder-gray-600 text-base outline-none transition-colors duration-200 resize-none"
            ></textarea>
          </div>

          <!-- Submit -->
          <Button type="submit" size="xl" fullWidth>Envoyer le projet</Button>

          <!-- Message succès -->
          <div id="form-success" class="hidden text-center py-6">
            <div class="font-display font-bold text-sage text-2xl mb-2">Message envoyé !</div>
            <p class="font-body text-gray-400">On vous revient sous 48h. Promis.</p>
          </div>
        </form>
      </div>

      <!-- Infos contact -->
      <aside class="space-y-6">
        <!-- Contact direct -->
        <div class="card-glass rounded-2xl p-8">
          <h3 class="font-display font-semibold text-creme text-sm uppercase tracking-widest mb-6">Contact direct</h3>
          <div class="space-y-4">
            <a
              href="mailto:contact@huedata.fr"
              class="flex items-center gap-3 text-gray-400 hover:text-creme transition-colors group"
            >
              <div class="w-10 h-10 rounded-xl bg-magenta/10 flex items-center justify-center text-magenta group-hover:bg-magenta/20 transition-colors">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                  <polyline points="22,6 12,13 2,6"/>
                </svg>
              </div>
              <span class="text-sm">contact@huedata.fr</span>
            </a>
            <a
              href="https://linkedin.com"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-3 text-gray-400 hover:text-electric transition-colors group"
            >
              <div class="w-10 h-10 rounded-xl bg-electric/10 flex items-center justify-center text-electric group-hover:bg-electric/20 transition-colors">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
                </svg>
              </div>
              <span class="text-sm">Stéphane Laurent</span>
            </a>
          </div>
        </div>

        <!-- Zone géo -->
        <div class="card-glass rounded-2xl p-8">
          <h3 class="font-display font-semibold text-creme text-sm uppercase tracking-widest mb-4">Zone d'intervention</h3>
          <p class="font-body text-gray-400 text-sm leading-relaxed">
            Basé en Bourgogne-Franche-Comté, interventions sur toute la France.
          </p>
          <div class="mt-4 flex flex-wrap gap-2">
            {['BFC', 'Alsace', 'Île-de-France', 'National'].map((zone) => (
              <span class="text-xs font-body text-gray-500 border border-gray-700 px-3 py-1 rounded-full">{zone}</span>
            ))}
          </div>
        </div>

        <!-- Délai -->
        <div class="rounded-2xl p-8 border border-mustard/20" style="background: var(--color-mustard)10;">
          <div class="font-display font-bold text-mustard text-4xl mb-2">48h</div>
          <div class="font-body text-gray-400 text-sm">Délai de réponse garanti pour toute demande.</div>
        </div>
      </aside>
    </div>
  </section>
</Layout>

<script>
  import gsap from 'gsap';

  // Animate form fields on load
  gsap.fromTo('.form-field',
    { opacity: 0, y: 20 },
    { opacity: 1, y: 0, duration: 0.5, stagger: 0.08, ease: 'power3.out', delay: 0.3 }
  );

  // Project type radio styling
  document.querySelectorAll<HTMLInputElement>('input[name="project_type"]').forEach((input) => {
    input.addEventListener('change', () => {
      document.querySelectorAll('.project-type-label span').forEach((span) => {
        (span as HTMLElement).style.borderColor = '';
        (span as HTMLElement).style.color = '';
        (span as HTMLElement).style.background = '';
      });
      const span = input.nextElementSibling as HTMLElement;
      if (span) {
        span.style.borderColor = '#E94560';
        span.style.color = '#F8F6F2';
        span.style.background = '#E9456015';
      }
    });
  });

  // Form submission feedback (demo)
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const success = document.getElementById('form-success');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    // In production: submit to formspree or your backend
    // For demo, show success message
    form.style.opacity = '0.5';
    form.style.pointerEvents = 'none';
    success?.classList.remove('hidden');
    gsap.fromTo(success, { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.5, ease: 'power3.out' });
  });
</script>
