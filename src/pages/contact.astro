---
export const prerender = true;

import Layout from "../layouts/Layout.astro";
import Button from "../components/ui/Button.astro";
import FormField from "../components/ui/FormField.astro";
import FormInput from "../components/ui/FormInput.astro";
import IconMail from "../assets/icons/IconMail.svg";
import IconLinkedin from "../assets/icons/IconLinkedin.svg";
import SectionHeader from "../components/ui/SectionHeader.astro";

const projectTypes = [
  "Étude de public / satisfaction",
  "Analyse de billetterie",
  "Étude d'impact économique",
  "Diagnostic stratégique",
  "Étude qualitative",
  "Autre",
];

const sectors = [
  "Festival de musiques actuelles",
  "Salle de concert / SMAC",
  "Musée / Patrimoine",
  "Club sportif",
  "Collectivité territoriale",
  "Association culturelle",
  "Autre",
];
---

<Layout
  title="Contact — HueData"
  description="Décrivez votre projet à HueData. Réponse sous 48h pour toute demande d'étude ou de conseil en marketing culturel."
>
  {/* Hero */}
  <section class="relative overflow-hidden bg-noir px-6 pt-40 pb-16">
    <div aria-hidden="true" class="pointer-events-none absolute inset-0">
      <div
        class="blur-blob absolute -top-[150px] -left-[100px] h-[400px] w-[400px] bg-magenta opacity-15!"
      >
      </div>
      <div
        class="blur-blob absolute right-0 bottom-0 h-[300px] w-[300px] bg-electric opacity-10!"
      >
      </div>
    </div>
    <div class="relative z-10 mx-auto max-w-3xl text-center">
      <SectionHeader tag="Parlons data" tagCentered as="h1" size="lg" titleClass="mb-6 tracking-tight">
        Décrire<br />
        <span class="text-gradient-magenta">votre projet.</span>
      </SectionHeader>
      <p class="font-body text-xl leading-relaxed text-gray-400">
        On répond sous 48h. Pas de devis automatisé, pas de template. Une vraie
        conversation.
      </p>
    </div>
  </section>

  {/* Formulaire + infos */}
  <section class="bg-noir px-6 py-12 pb-32">
    <div class="mx-auto grid max-w-6xl gap-12 md:grid-cols-3">
      {/* Formulaire */}
      <div class="md:col-span-2">
        <form
          id="contact-form"
          name="contact"
          class="space-y-6"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          novalidate
        >
          <input type="hidden" name="form-name" value="contact" />
          <p class="hidden">
            <label>Ne pas remplir : <input name="bot-field" /></label>
          </p>
          {/* Nom + Organisation */}
          <div class="grid gap-4 sm:grid-cols-2">
            <FormField label="Votre nom" htmlFor="name" required>
              <FormInput
                id="name"
                name="name"
                required
                autocomplete="name"
                minlength={2}
                placeholder="Florent Sanseigne"
              />
            </FormField>
            <FormField label="Organisation" htmlFor="organization" required>
              <FormInput
                id="organization"
                name="organization"
                required
                autocomplete="organization"
                placeholder="No Logo Festival"
              />
            </FormField>
          </div>

          {/* Email */}
          <FormField label="Email" htmlFor="email" required>
            <FormInput
              type="email"
              id="email"
              name="email"
              required
              autocomplete="email"
              placeholder="florent@no-logo.fr"
            />
          </FormField>

          {/* Type de projet */}
          <FormField label="Type de projet" spacious>
            <div class="flex flex-wrap gap-2">
              {
                projectTypes.map((type) => (
                  <label class="project-type-label cursor-pointer">
                    <input
                      type="radio"
                      name="project_type"
                      value={type}
                      class="sr-only"
                    />
                    <span class="inline-block cursor-pointer rounded-full border border-gray-700 px-4 py-2 font-body text-sm text-gray-400 transition-all duration-200 select-none hover:border-magenta hover:text-creme">
                      {type}
                    </span>
                  </label>
                ))
              }
            </div>
          </FormField>

          {/* Secteur */}
          <FormField label="Secteur d'activité" htmlFor="sector">
            <FormInput as="select" id="sector" name="sector">
              <option value="">Choisissez votre secteur</option>
              {sectors.map((s) => <option value={s}>{s}</option>)}
            </FormInput>
          </FormField>

          {/* Message */}
          <FormField label="Décrivez votre projet" htmlFor="message" required>
            <FormInput
              as="textarea"
              id="message"
              name="message"
              required
              minlength={20}
              rows={6}
              placeholder="Contexte, objectifs, échéance, budget indicatif..."
            />
          </FormField>

          {/* Submit */}
          <Button type="submit" size="xl" fullWidth>
            <span id="submit-text">Envoyer le projet</span>
            <span id="submit-loading" class="hidden items-center gap-2">
              <svg class="h-5 w-5 animate-spin" viewBox="0 0 24 24" fill="none">
                <circle
                  class="opacity-25"
                  cx="12"
                  cy="12"
                  r="10"
                  stroke="currentColor"
                  stroke-width="4"></circle>
                <path
                  class="opacity-75"
                  fill="currentColor"
                  d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
              </svg>
              Envoi en cours…
            </span>
          </Button>

          {/* Message succès */}
          <div id="form-success" class="hidden py-6 text-center">
            <div class="mb-2 font-display text-2xl font-bold text-sage">
              Message envoyé !
            </div>
            <p class="font-body text-gray-400">
              On vous revient sous 48h. Promis.
            </p>
          </div>

          {/* Message erreur */}
          <div
            id="form-error"
            class="hidden rounded-xl border border-magenta/30 bg-magenta/10 px-5 py-4 text-center"
          >
            <p class="font-body text-sm text-magenta">
              Une erreur est survenue. Merci de réessayer ou d’envoyer un email
              à
              <a href="mailto:contact@huedata.fr" class="underline"
                >contact@huedata.fr</a
              >.
            </p>
          </div>
        </form>
      </div>

      {/* Infos contact */}
      <aside class="space-y-6">
        {/* Contact direct */}
        <div class="card-glass rounded-2xl p-8">
          <h3
            class="mb-6 font-display text-sm font-semibold tracking-widest text-creme uppercase"
          >
            Contact direct
          </h3>
          <div class="space-y-4">
            <a
              href="mailto:contact@huedata.fr"
              class="group flex items-center gap-3 text-gray-400 transition-colors hover:text-creme"
            >
              <div
                class="flex h-10 w-10 items-center justify-center rounded-xl bg-magenta/10 text-magenta transition-colors group-hover:bg-magenta/20"
              >
                <IconMail class="h-5 w-5" />
              </div>
              <span class="text-sm">contact@huedata.fr</span>
            </a>
            <a
              href="https://www.linkedin.com/in/st%C3%A9phane-laurent-prof/"
              target="_blank"
              rel="noopener noreferrer"
              class="group flex items-center gap-3 text-gray-400 transition-colors hover:text-electric"
            >
              <div
                class="flex h-10 w-10 items-center justify-center rounded-xl bg-electric/10 text-electric transition-colors group-hover:bg-electric/20"
              >
                <IconLinkedin class="h-5 w-5" />
              </div>
              <span class="text-sm">Stéphane Laurent</span>
            </a>
          </div>
        </div>

        {/* Zone géo */}
        <div class="card-glass rounded-2xl p-8">
          <h3
            class="mb-4 font-display text-sm font-semibold tracking-widest text-creme uppercase"
          >
            Zone d'intervention
          </h3>
          <p class="font-body text-sm leading-relaxed text-gray-400">
            Basé en Bourgogne-Franche-Comté, interventions sur toute la France.
          </p>
          <div class="mt-4 flex flex-wrap gap-2">
            {
              ["BFC", "Alsace", "Île-de-France", "National"].map((zone) => (
                <span class="rounded-full border border-gray-700 px-3 py-1 font-body text-xs text-gray-400">
                  {zone}
                </span>
              ))
            }
          </div>
        </div>

        {/* Délai */}
        <div class="rounded-2xl border border-mustard/20 bg-mustard/5 p-8">
          <div class="mb-2 font-display text-4xl font-bold text-mustard">
            48h
          </div>
          <div class="font-body text-sm text-gray-400">
            Délai de réponse garanti pour toute demande.
          </div>
        </div>
      </aside>
    </div>
  </section>
</Layout>

<script>
  import { fadeIn } from "../lib/animations";

  fadeIn('[data-animate="field"]', {
    stagger: 0.15,
    delay: 0.3,
  });

  // Project type radio styling
  document
    .querySelectorAll<HTMLInputElement>('input[name="project_type"]')
    .forEach((input) => {
      input.addEventListener("change", () => {
        document
          .querySelectorAll(".project-type-label span")
          .forEach((span) => {
            (span as HTMLElement).style.borderColor = "";
            (span as HTMLElement).style.color = "";
            (span as HTMLElement).style.background = "";
          });
        const span = input.nextElementSibling as HTMLElement;
        if (span) {
          span.style.borderColor = "#E94560";
          span.style.color = "#F8F6F2";
          span.style.background = "#E9456015";
        }
      });
    });

  // Form submission feedback (demo)
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const success = document.getElementById("form-success");
  const error = document.getElementById("form-error");
  const submitText = document.getElementById("submit-text");
  const submitLoading = document.getElementById("submit-loading");
  const submitBtn = form?.querySelector(
    'button[type="submit"]',
  ) as HTMLButtonElement | null;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    error?.classList.add("hidden");

    // Loading state
    if (submitBtn) submitBtn.disabled = true;
    submitText?.classList.add("hidden");
    submitLoading?.classList.remove("hidden");
    submitLoading?.classList.add("inline-flex");

    try {
      const data = new FormData(form);
      await fetch("/", {
        method: "POST",
        headers: { "Content-Type": "application/x-www-form-urlencoded" },
        body: new URLSearchParams(
          data as unknown as Record<string, string>,
        ).toString(),
      });
      form.style.opacity = "0.5";
      form.style.pointerEvents = "none";
      success?.classList.remove("hidden");
      fadeIn(success, { duration: 0.5 });
    } catch {
      error?.classList.remove("hidden");
      fadeIn(error, { y: 10, duration: 0.4 });
    } finally {
      if (submitBtn) submitBtn.disabled = false;
      submitText?.classList.remove("hidden");
      submitLoading?.classList.add("hidden");
      submitLoading?.classList.remove("inline-flex");
    }
  });
</script>
