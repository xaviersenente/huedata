---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import CTA from "../../components/sections/CTA.astro";
import Card from "../../components/ui/Card.astro";
import { domainLabels, domainActiveClass } from "../../data/domains";

const allRefs = await getCollection("references");
const domains = Object.keys(domainLabels);
---

<Layout
  title="Références — HueData"
  description="Découvrez les projets menés par HueData : festivals, salles de concert, musées, clubs sportifs et collectivités."
>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-noir px-6 pt-40 pb-20">
    <div aria-hidden="true" class="pointer-events-none absolute inset-0">
      <div
        class="blur-blob absolute -top-[200px] -left-[100px] h-[500px] w-[500px] bg-mustard opacity-15!"
      >
      </div>
    </div>
    <div class="relative z-10 mx-auto max-w-7xl">
      <span
        class="mb-6 inline-flex items-center gap-2 text-sm tracking-widest text-gray-400 uppercase"
      >
        <span class="h-px w-6 bg-mustard"></span>
        Nos projets
      </span>
      <h1
        class="mb-6 font-display text-[clamp(3rem,7vw,6rem)] leading-[1] font-bold tracking-tight text-creme"
      >
        {allRefs.length} projets,<br />
        <span class="text-gradient-mustard">autant d'histoires.</span>
      </h1>
      <p class="max-w-2xl font-body text-xl leading-relaxed text-gray-400">
        Des festivals aux musées, des clubs sportifs aux collectivités : chaque
        mission est unique, chaque donnée raconte quelque chose.
      </p>
    </div>
  </section>

  <!-- Filtres + Grille -->
  <section class="bg-noir px-6 py-12">
    <div class="mx-auto max-w-7xl">
      <!-- Filtres -->
      <div class="mb-12 flex flex-wrap gap-3" id="filters">
        <button
          class="filter-btn active rounded-full border border-creme bg-creme px-5 py-2.5 font-display text-sm font-semibold text-noir transition-all duration-300"
          data-filter="all"
        >
          Tous ({allRefs.length})
        </button>
        {
          domains.map((domain) => {
            const count = allRefs.filter(
              (r) => r.data.domain === domain,
            ).length;
            if (count === 0) return null;
            return (
              <button
                class="filter-btn hover:border-opacity-60 rounded-full border border-gray-700 px-5 py-2.5 font-display text-sm font-semibold text-gray-400 transition-all duration-300"
                data-filter={domain}
                data-active-class={domainActiveClass[domain]}
              >
                {domainLabels[domain]} ({count})
              </button>
            );
          })
        }
      </div>

      <!-- Grille -->
      <div
        class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-3"
        id="refs-grid"
      >
        {
          allRefs.map((ref) => (
            <Card entry={ref} variant="grid" headingLevel={2} />
          ))
        }
      </div>
    </div>
  </section>

  <CTA />
</Layout>

<style is:global>
  #refs-grid .ref-card {
    opacity: 0;
    transform: translateY(16px);
  }
  @media (prefers-reduced-motion: reduce) {
    #refs-grid .ref-card {
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  import { gsap } from "../../lib/gsap";

  const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  const filterBtns = document.querySelectorAll<HTMLElement>(".filter-btn");
  const cards = document.querySelectorAll<HTMLElement>(".ref-card");

  // Init animation
  if (reduced) {
    gsap.set(cards, { opacity: 1, y: 0 });
  } else {
    gsap.to(cards, {
      opacity: 1,
      y: 0,
      duration: 0.45,
      stagger: 0.06,
      ease: "power3.out",
    });
  }

  const INACTIVE = ["text-gray-400", "border-gray-700"];
  const ALL_ACTIVE = ["bg-creme", "text-noir", "border-creme"];

  // Filter logic
  filterBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      const filter = btn.dataset.filter ?? "all";

      filterBtns.forEach((b) => {
        const active = b.dataset.activeClass?.split(" ") ?? ALL_ACTIVE;
        b.classList.remove("active", ...active);
        b.classList.add(...INACTIVE);
      });

      const active = btn.dataset.activeClass?.split(" ") ?? ALL_ACTIVE;
      btn.classList.remove(...INACTIVE);
      btn.classList.add("active", ...active);

      cards.forEach((card) => {
        const domain = card.dataset.domain ?? "";
        const visible = filter === "all" || domain === filter;
        card.style.display = visible ? "" : "none";
      });
    });
  });
</script>
