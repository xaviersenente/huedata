---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Button from "../../components/ui/Button.astro";
import { domainLabels, domainSlugStyles } from "../../data/domains";

export async function getStaticPaths() {
  const refs = await getCollection("references");
  return refs.map((ref) => ({
    params: { slug: ref.slug },
    props: { ref },
  }));
}

const { ref } = Astro.props;
const { Content } = await render(ref);

const dc = domainSlugStyles[ref.data.domain];
const label = domainLabels[ref.data.domain];
---

<Layout
  title={`${ref.data.title} — HueData`}
  description={`Étude de cas HueData pour ${ref.data.client} — ${ref.data.location}`}
>
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Accueil",
          item: "https://huedata.fr/",
        },
        {
          "@type": "ListItem",
          position: 2,
          name: "Références",
          item: "https://huedata.fr/references/",
        },
        { "@type": "ListItem", position: 3, name: ref.data.title },
      ],
    })}
  />
  <!-- Hero étude de cas -->
  <section class="relative overflow-hidden bg-noir px-6 pt-40 pb-20">
    <div aria-hidden="true" class="pointer-events-none absolute inset-0">
      <div
        class={`blur-blob absolute w-[600px] h-[600px] -top-[250px] -left-[150px] opacity-[0.12]! ${dc.bg}`}
      >
      </div>
    </div>

    <div class="relative z-10 mx-auto max-w-5xl">
      <!-- Breadcrumb -->
      <nav
        class="mb-10 flex items-center gap-2 text-sm text-gray-500"
        aria-label="Fil d'Ariane"
      >
        <a href="/" class="transition-colors hover:text-creme">Accueil</a>
        <span>/</span>
        <a href="/references" class="transition-colors hover:text-creme"
          >Références</a
        >
        <span>/</span>
        <span class="text-gray-400">{ref.data.title}</span>
      </nav>

      <!-- Badge domaine -->
      <div class="mb-6 flex items-center gap-3">
        <span
          class={`inline-flex items-center gap-2 text-sm font-semibold uppercase tracking-widest px-4 py-1.5 rounded-full border ${dc.bgBadge} ${dc.text} ${dc.borderLight}`}
        >
          <span class={`w-2 h-2 rounded-full ${dc.bg}`}></span>
          {label}
        </span>
        <span class="text-sm text-gray-500">{ref.data.year}</span>
      </div>

      <h1
        class="mb-4 font-display text-[clamp(3rem,6vw,5.5rem)] leading-[1.0] font-bold tracking-[-0.03em] text-creme"
      >
        {ref.data.title}
      </h1>
      <p class="mb-10 font-body text-xl text-gray-400">
        {ref.data.location} · {ref.data.client}
      </p>

      <!-- Stats clés -->
      {
        ref.data.stats && ref.data.stats.length > 0 && (
          <div class="flex flex-wrap gap-8 border-t border-gray-800 pt-8">
            {ref.data.stats.map((stat) => (
              <div>
                <div class={`font-display text-4xl font-bold ${dc.text}`}>
                  {stat.value}
                </div>
                <div class="mt-1 font-body text-sm text-gray-400">
                  {stat.label}
                </div>
              </div>
            ))}
          </div>
        )
      }
    </div>
  </section>

  <!-- Contenu -->
  <section class="bg-noir px-6 py-12">
    <div class="mx-auto grid max-w-5xl gap-12 md:grid-cols-3">
      <!-- Sidebar -->
      <aside class="space-y-8 md:col-span-1">
        <!-- Services -->
        {
          ref.data.services && ref.data.services.length > 0 && (
            <div class="card-glass rounded-2xl p-8">
              <h3 class="mb-6 font-display text-sm font-semibold tracking-widest text-creme uppercase">
                Missions
              </h3>
              <ul class="space-y-3">
                {ref.data.services.map((s: string) => (
                  <li class="flex items-start gap-3">
                    <span
                      class={`mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full ${dc.bg}`}
                    />
                    <span class="font-body text-sm text-gray-400">{s}</span>
                  </li>
                ))}
              </ul>
            </div>
          )
        }

        <!-- Témoignage -->
        {
          ref.data.testimonial && (
            <div
              class={`relative overflow-hidden rounded-2xl border border-gray-800 p-8 ${dc.bgSubtle}`}
            >
              <div
                class={`pointer-events-none absolute top-4 right-4 font-display text-7xl leading-none font-bold select-none ${dc.textLight}`}
              >
                "
              </div>
              <div
                class={`absolute top-0 bottom-0 left-0 w-1 rounded-l-2xl ${dc.bg}`}
              />
              <p class="relative z-10 mb-6 font-body text-sm leading-relaxed text-gray-400 italic">
                "{ref.data.testimonial.quote}"
              </p>
              <div class="relative z-10">
                <div class="font-display text-sm font-semibold text-creme">
                  {ref.data.testimonial.author}
                </div>
                <div class="mt-1 font-body text-xs text-gray-500">
                  {ref.data.testimonial.role}
                </div>
              </div>
            </div>
          )
        }

        <!-- CTA latéral -->
        <a
          href="/contact"
          class={`block rounded-2xl p-8 text-center border transition-all duration-300 hover:scale-105 ${dc.bgSoft} ${dc.borderLight}`}
        >
          <p class="mb-4 font-body text-sm text-gray-400">
            Un projet similaire ?
          </p>
          <span class={`font-display font-bold text-base ${dc.text}`}
            >Discutons →</span
          >
        </a>
      </aside>

      <!-- Contenu principal -->
      <article class="prose-case md:col-span-2">
        <Content />
      </article>
    </div>
  </section>

  <!-- Navigation entre projets -->
  <section class="border-t border-gray-800 bg-noir-soft px-6 py-16">
    <div class="mx-auto flex max-w-5xl items-center justify-between">
      <Button href="/references" variant="link" arrow={false}
        >← Toutes les références</Button
      >
      <Button href="/contact" size="md" class={dc.btnClass}
        >Démarrer un projet</Button
      >
    </div>
  </section>
</Layout>

<style>
  .prose-case :global(p) {
    color: rgb(136, 136, 136);
    font-family: var(--font-body);
    line-height: 1.8;
    margin-bottom: 1.25rem;
    font-size: 1.0625rem;
  }
  .prose-case :global(h2) {
    color: var(--color-creme);
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 700;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }
  .prose-case :global(h3) {
    color: var(--color-creme);
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
</style>

<script>
  import gsap from "gsap";

  gsap.fromTo(
    "article",
    { opacity: 0, y: 30 },
    { opacity: 1, y: 0, duration: 0.8, ease: "power3.out", delay: 0.3 },
  );
  gsap.fromTo(
    "aside",
    { opacity: 0, x: 30 },
    { opacity: 1, x: 0, duration: 0.8, ease: "power3.out", delay: 0.4 },
  );
</script>
