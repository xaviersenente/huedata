---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import Button from "../components/ui/Button.astro";
import huedada from "../assets/huedada3.avif";
---

<Layout
  title="404 — Page introuvable | HueData"
  description="Cette page n'existe pas ou a été déplacée."
>
  <section
    class="relative flex min-h-[calc(100vh-80px)] items-center overflow-hidden bg-noir px-6 pt-28 pb-16 md:pt-20"
  >
    {/* Blobs décoratifs */}
    <div aria-hidden="true" class="pointer-events-none absolute inset-0">
      <div
        class="blur-blob absolute -top-[150px] -right-[100px] h-[500px] w-[500px] bg-magenta opacity-10!"
      >
      </div>
      <div
        class="blur-blob absolute -bottom-[100px] -left-[150px] h-[400px] w-[400px] bg-electric opacity-10!"
      >
      </div>
      <div
        class="blur-blob absolute top-1/2 left-1/3 h-[300px] w-[300px] bg-mustard opacity-5!"
      >
      </div>
    </div>

    <div
      class="relative z-10 mx-auto grid max-w-6xl grid-cols-1 items-center gap-6 md:grid-cols-3 md:gap-16"
    >
      <div class="order-2 text-center md:order-1 md:col-span-2 md:text-left">
        <p
          class="mb-6 inline-flex items-center gap-2 text-sm tracking-widest text-gray-400 uppercase"
        >
          <span class="h-px w-6 bg-gray-400 max-md:hidden"></span>Page 404
        </p>

        <h1 class="mb-5 font-display font-bold text-creme">
          <span class="text-[clamp(3rem,0.6rem+8vw,7rem)] leading-[0.95]"
            >Hue dada...</span
          ><br />
          <span
            class="text-gradient-mustard text-[clamp(2.5rem,1.3rem+4vw,4.5rem)] leading-[1.1]"
            >mais pas par ici&nbsp;!</span
          >
        </h1>

        <p
          class="mb-3 max-w-md font-body text-lg leading-relaxed text-gray-400 md:text-xl"
        >
          Notre licorne a pris le mauvais chemin. Cette page n'existe pas&nbsp;—
          ou plus.
        </p>

        <p class="mb-8 max-w-sm font-body text-sm text-gray-400/50 italic">
          « 44&nbsp;000 lignes de data et même pas un GPS... »
        </p>

        <div class="flex flex-col gap-4 sm:flex-row md:justify-start">
          <Button href="/" size="md"> Retour à l'accueil </Button>
          <Button href="/references" variant="outline" size="md" arrow>
            Voir nos références
          </Button>
        </div>
      </div>

      <div class="order-1 flex justify-center md:order-2 md:justify-end">
        <Image
          src={huedada}
          alt="Hue dada — illustration cheval"
          class="w-32 md:w-80"
        />
      </div>
    </div>
  </section>
</Layout>
