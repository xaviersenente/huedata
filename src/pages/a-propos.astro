---
import Layout from "../layouts/Layout.astro";
import CTA from "../components/sections/CTA.astro";
import { Image } from "astro:assets";
import steph from "../assets/steph.avif";
import IconTeacher from "../assets/icons/IconTeacher.svg";
import IconSearch from "../assets/icons/IconSearch.svg";
import IconUsers from "../assets/icons/IconUsers.svg";
import IconChart from "../assets/icons/IconChart.svg";
import SectionHeader from "../components/ui/SectionHeader.astro";

const facettes = [
  {
    label: "L'Enseignant",
    accentClass: "[--card-accent:var(--color-magenta)]",
    Icon: IconTeacher,
    description:
      "15 ans d'enseignement marketing en IUT. +200 projets d'étudiants pilotés sur des missions réelles pour des acteurs culturels et événementiels.",
  },
  {
    label: "Le Chercheur",
    accentClass: "[--card-accent:var(--color-electric)]",
    Icon: IconSearch,
    description:
      "Chercheur associé au laboratoire ELLIADD depuis 2013. 12 colloques, articles en revue A. Recherche appliquée sur les publics culturels et festivaliers.",
  },
  {
    label: "L'Homme de Terrain",
    accentClass: "[--card-accent:var(--color-sage)]",
    Icon: IconUsers,
    description:
      "Booker, manager de groupes, organisateur de concerts et de grands événements. Président de 2 associations, trésorier d'une 3ème. Le terrain, c'est son terrain.",
  },
  {
    label: "L'Analyste",
    accentClass: "[--card-accent:var(--color-mustard)]",
    Icon: IconChart,
    description:
      "Datamining, stratégie data-driven, études quanti/quali. 44 000 lignes de données n'ont aucun secret pour lui. Et ce qu'il cherche dedans, c'est votre public.",
  },
];

const timeline = [
  {
    year: "2013",
    label: "Chercheur associé ELLIADD",
    dotClass: "[--dot-accent:var(--color-electric)]",
    textClass: "text-electric",
  },
  {
    year: "2010",
    label: "Enseignant marketing IUT",
    dotClass: "[--dot-accent:var(--color-magenta)]",
    textClass: "text-magenta",
  },
  {
    year: "2009",
    label: "Fondation HueData",
    dotClass: "[--dot-accent:var(--color-mustard)]",
    textClass: "text-mustard",
  },
  {
    year: "2000s",
    label: "Booker & manager de groupes",
    dotClass: "[--dot-accent:var(--color-sage)]",
    textClass: "text-sage",
  },
  {
    year: "1990s",
    label: "Créateur d'un skateshop",
    dotClass: "[--dot-accent:var(--color-magenta)]",
    textClass: "text-magenta",
  },
];
---

<Layout
  title="À propos — HueData · Stéphane Laurent"
  description="HueData, c'est Stéphane Laurent : enseignant-chercheur, homme de terrain et analyste passionné des données culturelles."
>
  {/* Hero */}
  <section class="relative overflow-hidden bg-noir px-6 pt-40 pb-20">
    <div aria-hidden="true" class="pointer-events-none absolute inset-0">
      <div
        class="blur-blob absolute -top-[200px] -right-[100px] h-[500px] w-[500px] bg-sage opacity-15"
      >
      </div>
    </div>
    <div
      class="relative z-10 mx-auto grid max-w-7xl items-center gap-16 md:grid-cols-7"
    >
      <div class="col-span-4">
        <SectionHeader
          tag="Qui sommes-nous"
          tagColor="bg-sage"
          as="h1"
          size="lg"
          titleClass="mb-8 tracking-[-0.03em] text-[clamp(3rem,6vw,5.5rem)]"
        >
          HueData,<br />
          c'est <span class="text-gradient-magenta">Stéphane</span><br />
          Laurent.
        </SectionHeader>
        <p class="max-w-xl font-body text-xl leading-relaxed text-gray-400">
          Enseignant-chercheur, homme de terrain et analyste. 15 ans à faire
          parler les données du monde culturel et événementiel.
        </p>
      </div>

      {/* Portrait */}
      <div class="relative col-span-3">
        <div
          class="mx-auto flex aspect-square max-w-120 items-center justify-center overflow-hidden rounded-3xl bg-linear-to-br from-magenta via-electric to-mustard"
        >
          <Image src={steph} alt="Stéphane LAURENT" />
        </div>
        {/* Badges flottants */}
        <div class="card-glass absolute -top-4 -left-4 rounded-2xl px-5 py-4">
          <div class="font-display text-3xl font-bold text-mustard">12</div>
          <div class="font-body text-xs text-white">colloques</div>
        </div>
        <div
          class="card-glass absolute -right-4 -bottom-4 rounded-2xl px-5 py-4"
        >
          <div class="font-display text-3xl font-bold text-sage">15ans</div>
          <div class="font-body text-xs text-white">d'enseignement</div>
        </div>
      </div>
    </div>
  </section>

  {/* Manifeste */}
  <section class="border-y border-gray-800 bg-noir-soft px-6 py-20">
    <div class="mx-auto max-w-4xl text-center">
      <p
        class="font-display text-[clamp(1.4rem,0.14rem+4.2vw,3.5rem)] leading-tight font-bold tracking-[-0.02em] text-creme"
      >
        « Vos données ont des couleurs.<br />
        <span class="text-gradient-magenta">Votre public a une histoire.</span
        ><br />
        On la raconte ensemble. »
      </p>
    </div>
  </section>

  {/* 4 Facettes */}
  <section class="bg-noir px-6 py-24">
    <div class="mx-auto max-w-7xl">
      <SectionHeader tag="Portrait" tagColor="bg-electric" class="mb-16">
        Quatre rôles,<br />
        <span class="text-gradient-magenta">une passion.</span>
      </SectionHeader>

      <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
        {
          facettes.map((f) => (
            <div
              data-animate="facette"
              class:list={[
                "group card-glass relative overflow-hidden rounded-2xl border border-gray-800 p-10 transition-all duration-500",
                f.accentClass,
              ]}
            >
              <div class="absolute inset-0 rounded-2xl bg-radial-[ellipse_at_top_left] from-(--card-accent)/7 to-transparent to-60% opacity-0 transition-opacity duration-500 group-hover:opacity-100" />
              {/* <div class="absolute top-0 bottom-0 left-0 w-1 rounded-l-2xl opacity-0 transition-opacity duration-300 group-hover:opacity-100" /> */}
              <div class="relative z-10">
                <div class="mb-6 flex items-center gap-4">
                  <div class="facette-icon-wrap flex h-12 w-12 items-center justify-center rounded-xl bg-(--card-accent)/13 text-(--card-accent)">
                    <f.Icon />
                  </div>
                  <h3 class="font-display text-xl font-bold text-creme">
                    {f.label}
                  </h3>
                </div>
                <p class="font-body leading-relaxed text-gray-400">
                  {f.description}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  {/* Timeline */}
  <section class="bg-noir-soft px-6 py-24">
    <div class="mx-auto max-w-4xl">
      <SectionHeader
        tag="Parcours"
        tagColor="bg-mustard"
        size="sm"
        class="mb-16"
      >
        D'où ça vient,<br />
        <span class="text-gradient-mustard">où ça va.</span>
      </SectionHeader>

      <div class="relative">
        <div
          class="absolute top-0 bottom-0 left-6 w-px bg-gray-800 md:left-1/2"
        >
        </div>

        <div class="space-y-10">
          {
            timeline.map((item, i) => (
              <div
                data-animate="timeline"
                class={`flex gap-8 md:gap-0 ${i % 2 === 0 ? "md:flex-row" : "md:flex-row-reverse"} items-center`}
              >
                <div
                  class={`flex-1 ${i % 2 === 0 ? "md:pr-16 md:text-right" : "md:pl-16 md:text-left"} pl-16 md:pl-0`}
                >
                  <div class="mb-1 font-display text-lg font-bold text-creme">
                    {item.label}
                  </div>
                  <div
                    class={`font-display text-3xl font-bold ${item.textClass}`}
                  >
                    {item.year}
                  </div>
                </div>

                <div class="absolute left-6 z-10 shrink-0 md:relative md:left-auto">
                  <div
                    class:list={[
                      "h-4 w-4 rounded-full border-2 border-noir-soft bg-(--dot-accent) shadow-[0_0_12px_var(--dot-accent)]",
                      item.dotClass,
                    ]}
                  />
                </div>

                <div class="hidden flex-1 md:block" />
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <CTA />
</Layout>

<script>
  import { gsap } from "../lib/gsap";
  import { scrollReveal } from "../lib/animations";

  scrollReveal('[data-animate="facette"]', '[data-animate="facette"]');

  gsap.utils
    .toArray<HTMLElement>('[data-animate="timeline"]')
    .forEach((el, i) => {
      scrollReveal(el, el, {
        x: i % 2 === 0 ? -40 : 40,
        y: 0,
        duration: 0.7,
        start: "top 80%",
      });
    });
</script>
