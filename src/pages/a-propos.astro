---
import Layout from '../layouts/Layout.astro';
import CTA from '../components/sections/CTA.astro';
import { Image } from 'astro:assets';

import steph from '../assets/steph.avif';

const facettes = [
  {
    label: "L'Enseignant",
    color: '#E94560',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>`,
    description: '15 ans d\'enseignement marketing en IUT. +200 projets d\'étudiants pilotés sur des missions réelles pour des acteurs culturels et événementiels.',
  },
  {
    label: 'Le Chercheur',
    color: '#3A86FF',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>`,
    description: 'Chercheur associé au laboratoire ELLIADD depuis 2013. 12 colloques, articles en revue A. Recherche appliquée sur les publics culturels et festivaliers.',
  },
  {
    label: "L'Homme de Terrain",
    color: '#06D6A0',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    description: 'Booker, manager de groupes, organisateur de concerts et de grands événements. Président de 2 associations, trésorier d\'une 3ème. Le terrain, c\'est son terrain.',
  },
  {
    label: "L'Analyste",
    color: '#FFBE0B',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
    description: 'Datamining, stratégie data-driven, études quanti/quali. 44 000 lignes de données n\'ont aucun secret pour lui. Et ce qu\'il cherche dedans, c\'est votre public.',
  },
];

const timeline = [
  { year: '2013', label: 'Chercheur associé ELLIADD', color: '#3A86FF' },
  { year: '2010', label: 'Enseignant marketing IUT', color: '#E94560' },
  { year: '2009', label: 'Fondation HueData', color: '#FFBE0B' },
  { year: '2000s', label: 'Booker & manager de groupes', color: '#06D6A0' },
  { year: '1990s', label: 'Créateur d\'un skateshop', color: '#E94560' },
];
---

<Layout
  title="À propos — HueData · Stéphane Laurent"
  description="HueData, c'est Stéphane Laurent : enseignant-chercheur, homme de terrain et analyste passionné des données culturelles."
>
  <!-- Hero -->
  <section class="pt-40 pb-20 px-6 bg-noir relative overflow-hidden">
    <div aria-hidden="true" class="absolute inset-0 pointer-events-none">
      <div class="blur-blob absolute w-[500px] h-[500px] bg-sage" style="top: -200px; right: -100px; opacity: 0.15;"></div>
    </div>
    <div class="mx-auto max-w-7xl relative z-10 grid md:grid-cols-2 gap-16 items-center">
      <div>
        <span class="inline-flex items-center gap-2 text-sm text-gray-400 uppercase tracking-widest mb-6">
          <span class="w-6 h-px bg-sage"></span>
          Qui sommes-nous
        </span>
        <h1 class="font-display font-bold text-creme mb-8" style="font-size: clamp(3rem, 6vw, 5.5rem); line-height: 1.0; letter-spacing: -0.03em;">
          HueData,<br />
          c'est <span class="text-gradient-magenta">Stéphane</span><br />
          Laurent.
        </h1>
        <p class="font-body text-gray-400 text-xl leading-relaxed max-w-xl">
          Enseignant-chercheur, homme de terrain et analyste. 15 ans à faire parler les données du monde culturel et événementiel.
        </p>
      </div>

      <!-- Portrait placeholder -->
      <div class="relative">
        <div
          class="aspect-square rounded-3xl flex items-center justify-center overflow-hidden"
          style="background: linear-gradient(135deg, #E94560 0%, #3A86FF 50%, #FFBE0B 100%); max-width: 480px; margin: 0 auto;"
        >
          <Image src={steph} alt="Stéphane LAURENT"/>
          <!-- <div class="text-center p-12">
            <div class="font-display font-bold text-creme text-center leading-none mb-4" style="font-size: 7rem;">SL</div>
            <div class="font-display font-semibold text-creme/80 text-xl">Stéphane Laurent</div>
            <div class="font-body text-creme/60 text-sm mt-2">Fondateur HueData</div>
          </div> -->
        </div>
        <!-- Badges flottants -->
        <div class="absolute -bottom-4 -left-4 card-glass rounded-2xl px-5 py-4">
          <div class="font-display font-bold text-3xl text-mustard">12</div>
          <div class="font-body text-gray-400 text-xs">colloques</div>
        </div>
        <div class="absolute -top-4 -right-4 card-glass rounded-2xl px-5 py-4">
          <div class="font-display font-bold text-3xl text-sage">15ans</div>
          <div class="font-body text-gray-400 text-xs">d'enseignement</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Manifeste -->
  <section class="py-20 px-6 bg-noir-soft border-y border-gray-800">
    <div class="mx-auto max-w-4xl text-center">
      <p class="font-display font-bold text-creme leading-tight" style="font-size: clamp(1.8rem, 4vw, 3.5rem); letter-spacing: -0.02em;">
        « Nos données ont des couleurs.<br />
        <span class="text-gradient-magenta">Votre public a une histoire.</span><br />
        On la raconte ensemble. »
      </p>
    </div>
  </section>

  <!-- 4 Facettes -->
  <section class="py-24 px-6 bg-noir">
    <div class="mx-auto max-w-7xl">
      <div class="mb-16">
        <span class="inline-flex items-center gap-2 text-sm text-gray-400 uppercase tracking-widest mb-4">
          <span class="w-6 h-px bg-electric"></span>
          Portrait
        </span>
        <h2 class="font-display font-bold text-creme" style="font-size: clamp(2.5rem, 5vw, 4.5rem); line-height: 1.1;">
          Quatre rôles,<br />
          <span class="text-gradient-magenta">une passion.</span>
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {facettes.map((f) => (
          <div
            class="facette-card group relative rounded-2xl p-10 card-glass border border-gray-800 overflow-hidden transition-all duration-500 hover:border-opacity-60"
          >
            <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 rounded-2xl"
              style={`background: radial-gradient(ellipse at top left, ${f.color}12, transparent 60%);`}
            ></div>
            <div class="absolute left-0 top-0 bottom-0 w-1 rounded-l-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-300"
              style={`background: ${f.color};`}
            ></div>
            <div class="relative z-10">
              <div class="flex items-center gap-4 mb-6">
                <div class="w-12 h-12 rounded-xl flex items-center justify-center"
                  style={`background: ${f.color}20; color: ${f.color};`}
                  set:html={f.icon}
                ></div>
                <h3 class="font-display font-bold text-creme text-xl">{f.label}</h3>
              </div>
              <p class="font-body text-gray-400 leading-relaxed">{f.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="py-24 px-6 bg-noir-soft">
    <div class="mx-auto max-w-4xl">
      <div class="mb-16">
        <span class="inline-flex items-center gap-2 text-sm text-gray-400 uppercase tracking-widest mb-4">
          <span class="w-6 h-px bg-mustard"></span>
          Parcours
        </span>
        <h2 class="font-display font-bold text-creme" style="font-size: clamp(2.5rem, 5vw, 4rem); line-height: 1.1;">
          D'où ça vient,<br />
          <span class="text-gradient-mustard">où ça va.</span>
        </h2>
      </div>

      <div class="relative">
        <!-- Ligne verticale -->
        <div class="absolute left-6 md:left-1/2 top-0 bottom-0 w-px bg-gray-800"></div>

        <div class="space-y-10">
          {timeline.map((item, i) => (
            <div class={`timeline-item flex gap-8 md:gap-0 ${i % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'} items-center`}>
              <!-- Contenu -->
              <div class={`flex-1 ${i % 2 === 0 ? 'md:text-right md:pr-16' : 'md:text-left md:pl-16'} pl-16 md:pl-0`}>
                <div class="font-display font-bold text-creme text-lg mb-1">{item.label}</div>
                <div class="font-display font-bold text-3xl" style={`color: ${item.color};`}>{item.year}</div>
              </div>

              <!-- Dot -->
              <div class="absolute left-6 md:relative md:left-auto flex-shrink-0 z-10">
                <div
                  class="w-4 h-4 rounded-full border-2 border-noir-soft"
                  style={`background: ${item.color}; box-shadow: 0 0 12px ${item.color}60;`}
                ></div>
              </div>

              {/* Spacer right */}
              <div class="hidden md:block flex-1"></div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <CTA />
</Layout>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.fromTo('.facette-card',
    { opacity: 0, y: 40 },
    {
      opacity: 1,
      y: 0,
      duration: 0.7,
      stagger: 0.12,
      ease: 'power3.out',
      scrollTrigger: { trigger: '.facette-card', start: 'top 80%' },
    }
  );

  gsap.utils.toArray<HTMLElement>('.timeline-item').forEach((el, i) => {
    gsap.fromTo(el,
      { opacity: 0, x: i % 2 === 0 ? -40 : 40 },
      {
        opacity: 1,
        x: 0,
        duration: 0.7,
        ease: 'power3.out',
        scrollTrigger: { trigger: el, start: 'top 80%' },
      }
    );
  });
</script>
