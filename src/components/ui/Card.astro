---
import type { CollectionEntry } from "astro:content";
import { domainLabels, domainCardStyles } from "../../data/domains";

interface Props {
  entry: CollectionEntry<"references">;
  variant?: "featured" | "grid";
  headingLevel?: 2 | 3;
  class?: string;
}

const {
  entry,
  variant = "grid",
  headingLevel = 3,
  class: className = "",
} = Astro.props;

const { data } = entry;
const dc = domainCardStyles[data.domain];
const label = domainLabels[data.domain];
const isFeatured = variant === "featured";
const Heading = `h${headingLevel}` as "h2" | "h3";
---

<a
  href={`/references/${entry.slug}`}
  class:list={[
    "ref-card group relative overflow-hidden rounded-2xl border border-transparent transition-all duration-500",
    isFeatured ? `p-8 bg-domain-${data.domain}` : "card-glass p-7",
    dc.cardColor,
    isFeatured ? dc.cardBgFeatured : "[--card-bg:var(--color-noir)]",
    className,
  ]}
  data-domain={data.domain}
>
  <!-- Domain badge + year -->
  <div
    class:list={[
      "flex items-center justify-between",
      isFeatured ? "mb-6" : "mb-5",
    ]}
  >
    <div class="flex flex-wrap items-start gap-2">
      <span
        class={`inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-xs font-semibold tracking-wide uppercase ${dc.text} ${dc.bgMuted}`}
      >
        <span class={`h-1.5 w-1.5 rounded-full ${dc.dot}`}></span>
        {label}
      </span>

      <!-- "Phare" badge (grid variant only, when featured) -->
      {
        !isFeatured && data.featured && (
          <div class="inline-flex items-center gap-1.5 rounded-full border border-gray-400 px-3 py-1 text-xs font-semibold tracking-wide text-white uppercase opacity-30">
            ★ Phare
          </div>
        )
      }
    </div>
    <span class="text-xs text-gray-400">{data.year}</span>
  </div>

  <!-- Title -->
  <Heading
    class:list={[
      "mb-2 font-display font-bold text-creme transition-colors duration-300",
      isFeatured ? "text-2xl md:text-3xl" : "text-2xl group-hover:text-creme",
    ]}
  >
    {data.title}
  </Heading>

  <!-- Location -->
  <p
    class:list={[
      "font-body text-sm text-gray-400",
      isFeatured ? "mb-6" : "mb-5",
    ]}
  >
    {data.location}
  </p>

  <!-- Stats -->
  {
    data.stats && data.stats.length > 0 && (
      <div
        class:list={[
          "flex",
          isFeatured
            ? "mb-6 gap-4"
            : "mb-5 gap-5 border-t border-gray-800 pt-4",
        ]}
      >
        {data.stats.slice(0, 2).map((stat) => (
          <div>
            <div
              class:list={[
                "font-display font-bold",
                isFeatured ? "text-xl" : "text-lg",
                dc.text,
              ]}
            >
              {stat.value}
            </div>
            <div class="mt-0.5 text-xs text-gray-400">{stat.label}</div>
          </div>
        ))}
      </div>
    )
  }

  <!-- CTA -->
  {
    isFeatured ? (
      <div
        class={`flex items-center gap-2 text-sm font-semibold transition-all duration-300 group-hover:gap-3 ${dc.text}`}
      >
        Voir l'étude de cas
        <span class="transition-transform duration-300 group-hover:translate-x-1">
          →
        </span>
      </div>
    ) : (
      <div
        class={`flex items-center gap-1.5 text-xs font-semibold transition-all duration-300 group-hover:gap-2.5 ${dc.text}`}
      >
        Voir l'étude →
      </div>
    )
  }
</a>

<style is:global>
  @property --border-angle {
    syntax: "<angle>";
    initial-value: 0deg;
    inherits: false;
  }

  @keyframes card-border-rotate {
    to {
      --border-angle: 360deg;
    }
  }

  /* Gradient border — always visible */
  .ref-card {
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0.03)),
      linear-gradient(var(--card-bg), var(--card-bg)),
      conic-gradient(
        from var(--border-angle),
        transparent 65%,
        var(--card-color) 80%,
        var(--card-color) 90%,
        transparent
      );
    background-origin: padding-box, padding-box, border-box;
    background-clip: padding-box, padding-box, border-box;
  }

  /* Animated gradient border on hover */
  .ref-card:hover {
    animation: card-border-rotate 3s linear infinite;
  }
</style>
