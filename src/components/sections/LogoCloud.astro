---
// Bandeau défilant logos clients — construit depuis les références
import { getCollection } from "astro:content";
import { domainDotClass } from "../../data/domains";

const allRefs = await getCollection("references");
const marqueeRefs = allRefs.filter((r) => r.data.marquee);
---

<div
  class="relative overflow-hidden border-y border-gray-800 bg-noir-soft py-12 md:py-16"
>
  {/* Dégradés latéraux */}
  <div
    class="pointer-events-none absolute top-0 bottom-0 left-0 z-10 w-24 bg-linear-to-r from-noir-soft to-transparent"
  >
  </div>
  <div
    class="pointer-events-none absolute top-0 right-0 bottom-0 z-10 w-24 bg-linear-to-l from-noir-soft to-transparent"
  >
  </div>

  <div class="marquee-track">
    {
      [0, 1].map((copy) => (
        <div
          class="flex shrink-0 items-center gap-8 pr-16 md:gap-16"
          aria-hidden={copy > 0}
        >
          {marqueeRefs.map((ref) => (
            <a
              href={`/references/${ref.slug}`}
              class="flex items-center gap-3"
              tabindex={copy > 0 ? -1 : undefined}
            >
              <span
                class={`h-2 w-2 shrink-0 rounded-full ${domainDotClass[ref.data.domain]}`}
              />
              <span class="font-display font-semibold whitespace-nowrap text-gray-400 transition-colors hover:text-creme md:text-2xl">
                {ref.data.client}
              </span>
            </a>
          ))}
        </div>
      ))
    }
  </div>
</div>

<script>
  import gsap from "gsap";

  const track = document.querySelector<HTMLElement>(".marquee-track");
  const set1 = track?.firstElementChild as HTMLElement | null;

  if (
    track &&
    set1 &&
    !window.matchMedia("(prefers-reduced-motion: reduce)").matches
  ) {
    const width = set1.offsetWidth;
    const anim = gsap.to(track, {
      x: -width,
      duration: 50,
      ease: "none",
      repeat: -1,
    });

    track.addEventListener("mouseenter", () => anim.pause());
    track.addEventListener("mouseleave", () => anim.resume());
  }
</script>
