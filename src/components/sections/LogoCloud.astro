---
// Bandeau défilant logos clients
import { domainDotClass } from "../../data/domains";
import { clients } from "../../data/clients";
---

<div
  class="relative overflow-hidden border-y border-gray-800 bg-noir-soft py-12"
>
  <!-- Dégradés latéraux -->
  <div
    class="pointer-events-none absolute top-0 bottom-0 left-0 z-10 w-24 bg-linear-to-r from-noir-soft to-transparent"
  >
  </div>
  <div
    class="pointer-events-none absolute top-0 right-0 bottom-0 z-10 w-24 bg-linear-to-l from-noir-soft to-transparent"
  >
  </div>

  <div class="marquee-track">
    {
      [0, 1].map((copy) => (
        <div
          class="flex shrink-0 items-center gap-16 pr-16"
          aria-hidden={copy > 0}
        >
          {clients.map((client) => (
            <div class="flex items-center gap-3">
              <span
                class={`h-2 w-2 shrink-0 rounded-full ${domainDotClass[client.domain]}`}
              />
              <span class="cursor-default font-display text-sm font-semibold whitespace-nowrap text-gray-400 transition-colors hover:text-creme md:text-base">
                {client.name}
              </span>
            </div>
          ))}
        </div>
      ))
    }
  </div>
</div>

<script>
  import gsap from "gsap";

  const track = document.querySelector<HTMLElement>(".marquee-track");
  const set1 = track?.firstElementChild as HTMLElement | null;

  if (
    track &&
    set1 &&
    !window.matchMedia("(prefers-reduced-motion: reduce)").matches
  ) {
    const width = set1.offsetWidth;
    const anim = gsap.to(track, {
      x: -width,
      duration: 50,
      ease: "none",
      repeat: -1,
    });

    track.addEventListener("mouseenter", () => anim.pause());
    track.addEventListener("mouseleave", () => anim.resume());
  }
</script>
