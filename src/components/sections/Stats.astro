---
import { colorTextClass } from "../../data/domains";
import { stats } from "../../data/stats";
import SectionHeader from "../ui/SectionHeader.astro";
---

<section id="stats-section" class="bg-noir px-6 py-24 md:py-32">
  <div class="mx-auto max-w-7xl">
    {/* Header */}
    <header
      data-animate="stats-header"
      class="mb-20 flex flex-col gap-6 md:flex-row md:items-end md:justify-between"
    >
      <SectionHeader tag="En chiffres" tagColor="bg-sage">
        Des chiffres qui parlent.<br />
        <span class="text-gradient-mustard">Pour vous.</span>
      </SectionHeader>
      <p class="max-w-xs font-body text-base text-gray-400">
        15 ans de recherche appliquée et de terrain dans le secteur culturel et
        événementiel.
      </p>
    </header>

    {/* Grille stats */}
    <div class="grid grid-cols-2 lg:grid-cols-4">
      {
        stats.map((stat, i) => (
          <div class="border-gray-800 odd:border-r max-lg:nth-[-n+2]:border-b lg:not-last:border-r">
            <div
              data-animate="stat"
              class="flex min-h-36 flex-col bg-noir p-6 lg:min-h-48 lg:p-10"
              data-value={stat.value}
              data-prefix={stat.prefix}
              data-suffix={stat.suffix}
              data-index={i}
            >
              <div
                class={`mb-4 font-display text-[clamp(2.4rem,1.44rem+3.2vw,4rem)] leading-none font-bold ${colorTextClass[stat.color]}`}
              >
                {stat.prefix && <span class="">{stat.prefix}</span>}
                <span data-role="number">0</span>
                {stat.suffix && (
                  <span class="text-2xl lg:text-3xl">{stat.suffix}</span>
                )}
              </div>
              <div class="font-body text-sm text-gray-400 lg:text-base">
                {stat.label}
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  import { gsap, ScrollTrigger } from "../../lib/gsap";
  import { scrollReveal } from "../../lib/animations";

  scrollReveal('[data-animate="stats-header"]', "#stats-section", {
    y: 50,
    duration: 1,
  });
  scrollReveal('[data-animate="stat"]', "#stats-section", {
    start: "top 65%",
  });

  // CountUp animation
  document
    .querySelectorAll<HTMLElement>('[data-animate="stat"]')
    .forEach((card) => {
      const target = parseInt(card.dataset.value ?? "0", 10);
      const numberEl = card.querySelector('[data-role="number"]');
      if (!numberEl) return;

      ScrollTrigger.create({
        trigger: card,
        start: "top 80%",
        once: true,
        onEnter: () => {
          gsap.to(
            { val: 0 },
            {
              val: target,
              duration: 2,
              ease: "power2.out",
              onUpdate: function () {
                const v = Math.round(this.targets()[0].val);
                numberEl.textContent =
                  v >= 1000 ? v.toLocaleString("fr-FR") : String(v);
              },
            },
          );
        },
      });
    });
</script>
