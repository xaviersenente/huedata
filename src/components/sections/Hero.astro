---
// Hero — Proposition A "Hue Dada"
import Button from "../ui/Button.astro";
---

<section
  id="hero"
  class="relative flex min-h-screen flex-col justify-center overflow-hidden bg-noir px-6 pt-20"
>
  {/* Blobs couleurs arrière-plan */}
  <div aria-hidden="true" class="pointer-events-none absolute inset-0">
    <div
      class="blur-blob absolute top-[-150px] left-[-100px] h-[500px] w-[500px] animate-[pulse-glow_6s_ease-in-out_infinite] bg-magenta"
    >
    </div>
    <div
      class="blur-blob absolute top-[30%] right-[-80px] h-[400px] w-[400px] animate-[pulse-glow_8s_ease-in-out_infinite_2s] bg-electric"
    >
    </div>
    <div
      class="blur-blob absolute bottom-[-100px] left-[30%] h-[350px] w-[350px] animate-[pulse-glow_7s_ease-in-out_infinite_4s] bg-mustard"
    >
    </div>
    {/* Grid overlay */}
    <div
      class="absolute inset-0 [background-image:linear-gradient(rgba(248,246,242,0.5)_1px,transparent_1px),linear-gradient(90deg,rgba(248,246,242,0.5)_1px,transparent_1px)] [background-size:80px_80px] opacity-5"
    >
    </div>
  </div>

  {/* Contenu hero */}
  <div class="relative z-10 mx-auto w-full max-w-7xl py-24 md:py-32">
    {/* Tag accrocheur */}
    <div id="hero-tag" class="mb-10 flex items-center gap-3 opacity-0">
      <span class="inline-block h-px w-8 bg-magenta"></span>
      <span class="font-body text-sm tracking-widest text-gray-400 uppercase">
        Marketing d'études · Événementiel · Culture
      </span>
    </div>

    {/* Titre principal */}
    <h1
      class="mb-8 font-display text-[clamp(3.5rem,0.2rem+11vw,9rem)] leading-[0.95] font-bold text-creme"
    >
      <span class="hero-line block overflow-hidden">
        <span class="hero-word inline-block translate-y-full">Vos données</span>
      </span>
      <span class="hero-line block overflow-hidden">
        <span class="hero-word inline-block translate-y-full">
          ont des
          <em
            class="bg-[linear-gradient(135deg,var(--color-magenta)_0%,var(--color-electric)_50%,var(--color-mustard)_100%)] bg-clip-text text-transparent not-italic"
            >couleurs.</em
          >
        </span>
      </span>
    </h1>

    {/* Sous-titre */}
    <p
      id="hero-sub"
      class="mb-12 max-w-2xl font-body text-xl leading-normal text-gray-400 opacity-0 md:text-2xl"
    >
      On les lit, on les raconte, on les transforme en décisions.<br />
      <span class="font-bold text-creme">+200 projets pilotés</span> pour les festivals,
      salles et musées.
    </p>

    {/* CTA */}
    <div id="hero-ctas" class="flex flex-wrap items-center gap-4 opacity-0">
      <Button href="/contact" size="lg">Démarrer un projet</Button>
      <Button href="/references" variant="outline" size="lg" arrow={false}
        >Voir les projets</Button
      >
    </div>

    {/* Chiffre flottant décoratif */}
    <div
      id="hero-badge"
      class="absolute top-1/3 right-32 hidden -translate-y-1/2 animate-[float_8s_ease-in-out_infinite] flex-col items-center opacity-0 xl:flex"
    >
      <div class="card-glass rounded-2xl p-8 text-center">
        <div class="font-display text-6xl leading-none font-bold text-mustard">
          +200
        </div>
        <div class="mt-2 font-body text-sm text-gray-400">projets pilotés</div>
      </div>
    </div>
  </div>

  {/* Scroll indicator */}
  <div
    id="hero-scroll"
    class="absolute bottom-8 left-1/2 flex -translate-x-1/2 flex-col items-center gap-2 opacity-0 max-sm:hidden"
  >
    <span class="font-body text-xs tracking-widest text-creme/60 uppercase"
      >Scroll</span
    >
    <div class="h-12 w-px bg-linear-to-b from-white/60 to-transparent"></div>
  </div>
</section>

<script>
  import gsap from "gsap";

  const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (reduced) {
    gsap.set(
      ["#hero-tag", "#hero-sub", "#hero-ctas", "#hero-badge", "#hero-scroll"],
      { opacity: 1 },
    );
    gsap.set(".hero-word", { y: "0%" });
  } else {
    const tl = gsap.timeline({ defaults: { ease: "power4.out" } });

    // Tag
    tl.fromTo(
      "#hero-tag",
      { opacity: 0, y: 20 },
      { opacity: 1, y: 0, duration: 0.8 },
      0.2,
    );

    // Lignes de titre
    tl.to(".hero-word", { y: "0%", duration: 1, stagger: 0.15 }, 0.4);

    // Sous-titre
    tl.fromTo(
      "#hero-sub",
      { opacity: 0, y: 20 },
      { opacity: 1, y: 0, duration: 0.8 },
      0.9,
    );

    // CTAs
    tl.fromTo(
      "#hero-ctas",
      { opacity: 0, y: 20 },
      { opacity: 1, y: 0, duration: 0.8 },
      1.1,
    );

    // Badge
    tl.fromTo("#hero-badge", { opacity: 0 }, { opacity: 1, duration: 1 }, 1.3);

    // Scroll indicator
    tl.fromTo(
      "#hero-scroll",
      { opacity: 0 },
      { opacity: 1, duration: 0.8 },
      1.5,
    );
  }
</script>
