---
// Section CTA finale
import Button from "../ui/Button.astro";
import SectionHeader from "../ui/SectionHeader.astro";
import { statsSummary } from "../../data/stats";
---

<section
  id="cta-section"
  class="relative overflow-hidden bg-noir px-6 py-24 md:py-40"
>
  {/* Blobs décoratifs */}
  <div aria-hidden="true" class="pointer-events-none absolute inset-0">
    <div
      class="blur-blob absolute top-1/2 left-1/2 h-[600px] w-[600px] -translate-1/2 bg-electric opacity-15!"
    >
    </div>
    <div
      class="blur-blob absolute top-0 right-1/12 h-[300px] w-[300px] bg-magenta opacity-20!"
    >
    </div>
    <div
      class="blur-blob absolute bottom-0 left-1/12 h-[250px] w-[250px] bg-sage opacity-15!"
    >
    </div>
  </div>

  <div class="relative z-10 mx-auto max-w-4xl text-center">
    <div id="cta-content" class="opacity-0">
      <SectionHeader
        tag="Et vous ?"
        tagColor="bg-mustard"
        tagCentered
        size="xl"
        titleClass="mb-8 tracking-tight"
      >
        Vos données<br />
        méritent mieux<br />
        <span class="text-gradient-magenta">qu'un tableur.</span>
      </SectionHeader>

      <p
        class="mx-auto mb-12 max-w-xl font-body text-xl leading-relaxed text-gray-400"
      >
        Décrivez-nous votre projet. On vous répond sous 48h avec une approche
        personnalisée.
      </p>

      <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
        <Button
          href="/contact"
          size="xl"
          fullWidth
          class="hover:shadow-[0_0_60px_rgba(233,69,96,0.4)] sm:w-auto"
          >Démarrer un projet</Button
        >
        <Button
          href="mailto:contact@huedata.fr"
          variant="outline"
          size="xl"
          arrow={false}
          fullWidth
          class="sm:w-auto">contact@huedata.fr</Button
        >
      </div>

      {/* Mini-stats rassurantes */}
      <div class="mt-16 flex flex-wrap items-center justify-center gap-8">
        {
          statsSummary.map((item) => (
            <div class="text-center">
              <div class="font-display text-2xl font-bold text-creme">
                {item.v}
              </div>
              <div class="mt-1 font-body text-xs tracking-wider text-gray-400 uppercase">
                {item.l}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  import { scrollReveal } from "../../lib/animations";

  scrollReveal("#cta-content", "#cta-section", {
    duration: 1,
  });
</script>
