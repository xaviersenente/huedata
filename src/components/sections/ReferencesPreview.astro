---
import { getCollection } from "astro:content";
import Button from "../ui/Button.astro";
import Card from "../ui/Card.astro";

const allRefs = await getCollection("references");
const featured = allRefs.filter((r) => r.data.featured).slice(0, 4);
---

<section id="references-section" class="bg-noir px-6 py-24 md:py-32">
  <div class="mx-auto max-w-7xl">
    <!-- Header -->
    <div
      class="refs-header mb-16 flex flex-col gap-6 md:flex-row md:items-end md:justify-between"
    >
      <div>
        <span
          class="mb-4 inline-flex items-center gap-2 text-sm tracking-widest text-gray-400 uppercase"
        >
          <span class="h-px w-6 bg-mustard"></span>
          Projets phares
        </span>
        <h2
          class="font-display text-[clamp(2.5rem,5vw,4.5rem)] leading-[1.1] font-bold text-creme"
        >
          Ils nous font<br />
          <span class="text-gradient-mustard">confiance.</span>
        </h2>
      </div>
      <Button
        href="/references"
        variant="outline"
        size="md"
        arrow
        class="self-start">Toutes les références</Button
      >
    </div>

    <!-- Grille références -->
    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
      {
        featured.map((ref) => (
          <Card entry={ref} variant="featured" headingLevel={3} />
        ))
      }
    </div>
  </div>
</section>

<script>
  import { gsap, ScrollTrigger } from "../../lib/gsap";

  gsap.fromTo(
    ".refs-header",
    { opacity: 0, y: 50 },
    {
      opacity: 1,
      y: 0,
      duration: 1,
      ease: "power3.out",
      scrollTrigger: { trigger: "#references-section", start: "top 75%" },
    },
  );

  gsap.fromTo(
    ".ref-card",
    { opacity: 0, y: 40 },
    {
      opacity: 1,
      y: 0,
      duration: 0.7,
      stagger: 0.1,
      ease: "power3.out",
      scrollTrigger: { trigger: "#references-section", start: "top 65%" },
    },
  );
</script>
