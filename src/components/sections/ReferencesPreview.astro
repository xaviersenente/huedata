---
import { getCollection } from "astro:content";
import Button from "../ui/Button.astro";
import Card from "../ui/Card.astro";
import SectionHeader from "../ui/SectionHeader.astro";

const allRefs = (await getCollection("references")).sort(
  (a, b) => b.data.sortYear - a.data.sortYear,
);
const featured = allRefs.filter((r) => r.data.featured).slice(0, 4);
---

<section id="references-section" class="bg-noir px-6 py-24 md:py-32">
  <div class="mx-auto max-w-7xl">
    {/* Header */}
    <header
      data-animate="refs-header"
      class="mb-16 flex flex-col gap-6 md:flex-row md:items-end md:justify-between"
    >
      <SectionHeader tag="Projets phares" tagColor="bg-mustard">
        Ils nous font<br />
        <span class="text-gradient-mustard">confiance.</span>
      </SectionHeader>
      <Button
        href="/references"
        variant="outline"
        size="md"
        arrow
        class="self-start">Toutes les références</Button
      >
    </header>

    {/* Grille références */}
    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
      {
        featured.map((ref) => (
          <Card entry={ref} variant="featured" headingLevel={3} />
        ))
      }
    </div>
  </div>
</section>

<script>
  import { scrollReveal } from "../../lib/animations";

  scrollReveal('[data-animate="refs-header"]', "#references-section", {
    y: 50,
    duration: 1,
  });
  scrollReveal(".ref-card", "#references-section");
</script>
